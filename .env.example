# ---------------------------------------------------------------------------
# Shepherd environment configuration
# Copy to .env and fill in real values. .env is gitignored.
#
# The root dev scripts (npm run dev:hub / dev:mcp / migrate) auto-load .env via
# `tsx --env-file-if-exists=.env`, which requires Node >= 22.9. On older Node,
# export the variables in your shell instead.
# ---------------------------------------------------------------------------

# === Hub (Fastify + Postgres) — see packages/hub/src/config.ts ===

# REQUIRED. Postgres connection string used by the hub and migrations.
DATABASE_URL=postgres://user:password@localhost:5432/shepherd

# Self-host auth mode: TEAM_TOKEN + ALLOWED_WORKSPACE together. The hub requires
# at least one auth mode to be fully configured — either these two (self-host)
# or BFF_INTERNAL_TOKEN (hosted). Both may be set simultaneously.

# Shared secret that authenticates clients (MCP servers) to the hub.
TEAM_TOKEN=change-me

# The single workspace slug this self-host hub serves (seeded on boot).
ALLOWED_WORKSPACE=default

# OPTIONAL. Hosted auth mode: the shared secret a trusted platform BFF presents
# as the x-internal-token header. Setting this alone (no TEAM_TOKEN /
# ALLOWED_WORKSPACE) is a valid hosted-only configuration.
# BFF_INTERNAL_TOKEN=<secret>

# OPTIONAL. HMAC secret for verifying the BFF-signed operator identity proof on
# /admin/* routes. When unset the operator surface is unreachable (fail-closed).
# OPERATOR_IDENTITY_SECRET=<secret>

# OPTIONAL. When the hub sits behind a trusted reverse proxy (e.g. Cloud Run),
# set to true so request.ip reflects the real client for pre-auth throttling.
# Never enable on a hub exposed directly to the internet.
# TRUST_PROXY=true

# OPTIONAL. Verified-email domain for internal operator analytics (/admin/*).
# When unset, the operator surface is unreachable (fail-closed).
# OPERATOR_EMAIL_DOMAIN=example.com

# OPTIONAL. Where feedback-widget submissions are emailed. When unset, falls
# back to INVITE_EMAIL_FROM when email invites are configured.
# FEEDBACK_EMAIL_TO=feedback@yourdomain.com

# OPTIONAL. Sender label stamped on announcements sent from the dashboard.
# Default: admin
# HUB_ADMIN_LABEL=admin

# OPTIONAL. Email invites (all-or-nothing feature): when RESEND_API_KEY is set,
# INVITE_EMAIL_FROM and PUBLIC_WEB_URL become required; when unset, the email
# invite endpoint returns 501 and the hub boots fine without them.
# RESEND_API_KEY=<resend-api-key>
# INVITE_EMAIL_FROM=Shepherd <invites@yourdomain.com>
# PUBLIC_WEB_URL=https://app.example.com

# TCP port the hub HTTP server listens on. Default: 8080
HUB_PORT=8080

# Default lease/lock time-to-live in seconds when a client does not specify one.
# Default: 3600
DEFAULT_TTL_SECONDS=3600

# Minimum TTL in seconds the hub will accept for a lease/lock. Default: 30
MIN_TTL_SECONDS=30

# Age in seconds after which a session is considered stale (drives the
# active/offline label). Default: 120
STALE_AFTER_SECONDS=120

# OPTIONAL. How long change records stay visible, in seconds. Default: 259200 (3 days)
# CHANGE_RECORD_TTL_SECONDS=259200

# OPTIONAL. How long a dead agent's uncommitted change records stay visible
# after its last heartbeat, in seconds. Effective default: 900 (15 min)
# UNCOMMITTED_GRACE_SECONDS=900

# === MCP server (thin stdio client) — see packages/mcp-server/src/config.ts ===

# REQUIRED. Base URL of the hub the MCP server talks to. Must be a full valid
# URL. Plain http to a non-localhost host triggers a stderr warning (use https).
HUB_URL=http://localhost:8080

# Credential: exactly one of SHEPHERD_TOKEN / TEAM_TOKEN is required.
#  - SHEPHERD_TOKEN — hosted-hub credential (a minted `shp_…` token from the
#    dashboard). Carries its own workspace identity, so WORKSPACE is ignored.
#    Wins over TEAM_TOKEN when both are set.
#  - TEAM_TOKEN — self-host credential, matching the hub's TEAM_TOKEN (see above;
#    the hub section's TEAM_TOKEN is also read by the MCP server).
# SHEPHERD_TOKEN=shp_...

# OPTIONAL. Workspace slug (self-host only; ignored with SHEPHERD_TOKEN).
# Defaults to "default" — must match the hub's ALLOWED_WORKSPACE if overridden.
# WORKSPACE=default

# OPTIONAL identity overrides — each is auto-detected from git when unset.
# REPO=owner/repo
# BRANCH=main
# BASE_BRANCH=origin/main
# HUMAN=your-name
# PROGRAM=claude-code
# MODEL=<model-id>            # never auto-detected; set to show it in presence

# OPTIONAL. Heartbeat cadence in seconds. Default: 60
# HEARTBEAT_INTERVAL_SECONDS=60

# OPTIONAL. Directory for the announcement-push inbox. Default: ~/.shepherd/inbox
# If you override it, point the client hook/extension at the SAME dir.
# SHEPHERD_INBOX_DIR=~/.shepherd/inbox

# OPTIONAL. Set to 1/true/yes to disable automatic client hook installation.
# SHEPHERD_NO_AUTO_HOOKS=1

# OPTIONAL. Allow plain http:// to a non-localhost HUB_URL (not recommended).
# SHEPHERD_ALLOW_INSECURE_HTTP=1

# ---------------------------------------------------------------------------
# Production / Cloud Run overrides
# ---------------------------------------------------------------------------

# When deployed on Cloud Run, PORT is injected automatically (defaults to 8080).
# The hub reads HUB_PORT; the container CMD maps PORT → HUB_PORT at startup.
# You do NOT need to set this manually for Cloud Run.
PORT=8080

# Production DATABASE_URL uses the Cloud SQL Unix-socket form:
#   postgres://<user>:<password>@/<dbname>?host=/cloudsql/<PROJECT>:<REGION>:<INSTANCE>
# The exact value is printed by `gcloud run deploy` output; copy it after deploy.
# Example (replace all angle-bracket placeholders):
# DATABASE_URL=postgres://shepherd:<password>@/shepherd?host=/cloudsql/<PROJECT>:<REGION>:<INSTANCE>

# TEAM_TOKEN — generate once with `openssl rand -hex 32`, store in Secret Manager.
# Never commit the real value.
# TEAM_TOKEN=<secret-value-from-secret-manager>

# ALLOWED_WORKSPACE — set to your team's workspace identifier.
# ALLOWED_WORKSPACE=my-team

# TRUST_PROXY — set to true when deployed behind Cloud Run's load balancer.
# TRUST_PROXY=true
