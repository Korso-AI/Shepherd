{
  "name": "shepherd",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc -b && npm -w @korso/shepherd-ui run type-check && npm -w @korso/shepherd-ui run build",
    "test": "npm -w @korso/shepherd-ui run build:app && vitest run",
    "typecheck:test": "tsc -p packages/hub/tsconfig.test.json",
    "check": "npm run lint && npm run build && npm run typecheck:test && npm test",
    "dev:hub": "tsx --env-file-if-exists=.env watch packages/hub/src/index.ts",
    "dev:mcp": "tsx --env-file-if-exists=.env packages/mcp-server/src/index.ts",
    "migrate": "tsx --env-file-if-exists=.env packages/hub/src/migrate.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "latest",
    "@types/pg": "latest",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "tsx": "latest",
    "typescript": "^5",
    "typescript-eslint": "^8.63.0",
    "vitest": "latest"
  }
}
